# =============================================================================
# NexusAgent .gitignore
# =============================================================================
# Directory classification:
#   Core:      backend/, src/, frontend/, desktop/, deploy/, scripts/, start/
#   Runtime:   agent_workspace/, agent-workspace/, data/, logs/, sessions/
#   Reference: reference/, related_project/, arena_debate/, docs/
#   Generated: __pycache__/, node_modules/, dist/, build/, .eggs/
# =============================================================================

# ── Runtime data (never committed) ──────────────────────────────────────────
/agent_workspace/
/agent-workspace/
/data/
/logs/
/logs_*/
/sessions/
/new_task/

# ── Reference & external projects (kept out of core) ───────────────────────
/reference/
/related_project/
/arena_debate/

# ── Plans & internal docs ──────────────────────────────────────────────────
/plans/
/docs_self/
CLAUDE.md
AGENT.md
TeamWorkflow.md
DESIGN_AGENT_COMMUNICATION.md
MATRIX_MODULE_SUMMARY.md
OPTIMIZATION_PLAN_CN.md
PRODUCT_FEATURE_UI_ROADMAP.md
SCENARIO_WALKTHROUGH.md

# ── Experiment & benchmark data ────────────────────────────────────────────
/drafts/
/benchmark_test/gaia/
experiment_scripts/test_data/
cc_analysis_1.md

# ── Python bytecode & cache ────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# ── Python packaging & build ───────────────────────────────────────────────
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
.pdm-python
.pdm-build/
.pixi/
__pypackages__/

# ── Python virtual environments ────────────────────────────────────────────
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Test & coverage ───────────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ── Linter & type checker cache ───────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ── Node / Frontend ───────────────────────────────────────────────────────
node_modules/
.next/
*.tsbuildinfo

# ── Logs & temp files ─────────────────────────────────────────────────────
*.log
*.pid

# ── OS files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────
