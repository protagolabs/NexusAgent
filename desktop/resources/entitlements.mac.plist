<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for Electron's V8 engine -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (required by Electron) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow loading dylibs not signed by Apple -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access for API calls and Docker communication -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File access for project directory management -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
